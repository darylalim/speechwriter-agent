# Secrets
.env
# The web app reads config from .env via load_settings(), not st.secrets — but Streamlit
# will pick this file up if it ever exists, so it must never be committable.
.streamlit/secrets.toml

# Agent runtime output (drafts + persistent memory snapshot).
