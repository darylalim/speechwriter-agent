# Copy to `.env` and fill in. The CLI loads this automatically (python-dotenv).

# Required to run the agent (drafting). https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional. Enables the live web-research subagent. Without it, the agent writes
# from its own knowledge and flags unverified claims with [VERIFY]. https://tavily.com/
TAVILY_API_KEY=

# --- Optional overrides -----------------------------------------------------
# Model to use (default: claude-sonnet-5). Try claude-opus-4-8 for top quality.
# SPEECHWRITER_MODEL=claude-sonnet-5
# Tavily results per query (default: 5).
# SPEECHWRITER_MAX_RESEARCH_RESULTS=5
# Root dir the agent reads/writes under (default: the repo root).
# SPEECHWRITER_HOME=

# --- Optional: LangSmith tracing (observability; recommended) ---------------
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=speechwriter-agent
